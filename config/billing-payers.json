{
  "version": "1.0",
  "defaultCurrency": "CAD",
  "defaultCountry": "CA",
  "defaultProvince": "ON",
  "enabled": true,
  "patientPaymentMethods": [
    "cash",
    "check",
    "bank_transfer",
    "etransfer",
    "zelle",
    "card",
    "debit"
  ],
  "copayRules": {
    "defaultCopay": 0,
    "privateDefaultCoveragePercent": 80,
    "uninsuredMarkupPercent": 0,
    "collectCopayAtCheckIn": true
  },
  "provincialPayers": {
    "OHIP": {
      "name": "Ontario Health Insurance Plan (OHIP)",
      "province": "ON",
      "identifierSystem": "http://ehealthontario.ca/fhir/NamingSystem/id-on-patient-hcn",
      "claimTransport": "MCEDT",
      "eligibilityEndpoint": "",
      "feeSchedule": "ohip_fee_schedule",
      "notes": "Insured services billed to MOH; patient copay typically $0 for OHIP-insured visits"
    },
    "RAMQ": {
      "name": "Régie de l'assurance maladie du Québec (RAMQ)",
      "province": "QC",
      "claimTransport": "RAMQ_NET",
      "feeSchedule": "ramq_fee_schedule"
    },
    "MSP": {
      "name": "Medical Services Plan (BC)",
      "province": "BC",
      "claimTransport": "TELEPLAN",
      "feeSchedule": "msp_fee_schedule"
    },
    "AHCIP": {
      "name": "Alberta Health Care Insurance Plan",
      "province": "AB",
      "claimTransport": "HLINK",
      "feeSchedule": "ahcip_fee_schedule"
    }
  },
  "privateInsurers": {
    "BLUE_CROSS_CANADA": {
      "name": "Blue Cross Canada",
      "claimTransport": "EDI_837",
      "ediProfile": "837P"
    },
    "CANADA_LIFE": {
      "name": "Canada Life",
      "claimTransport": "portal"
    },
    "MANULIFE": {
      "name": "Manulife",
      "claimTransport": "portal"
    },
    "SUN_LIFE": {
      "name": "Sun Life",
      "claimTransport": "portal"
    },
    "GREEN_SHIELD": {
      "name": "Green Shield Canada",
      "claimTransport": "portal"
    },
    "DESJARDINS": {
      "name": "Desjardins Insurance",
      "claimTransport": "portal"
    }
  },
  "paymentGateways": {
    "stripe": {
      "enabled": false,
      "envPublicKey": "STRIPE_PUBLISHABLE_KEY",
      "supports": ["card", "debit"]
    },
    "square": {
      "enabled": false,
      "supports": ["card", "debit"]
    },
    "moneris": {
      "enabled": false,
      "supports": ["card", "debit"],
      "countries": ["CA"]
    }
  },
  "dunning": {
    "enabled": true,
    "reminderDaysAfterDue": [7, 14, 30],
    "suspendServicesAfterDays": 90
  },
  "workflow": {
    "primaryPayerOrder": ["provincial", "private", "wcb", "patient_pay"],
    "autoCreateClaimOnInvoice": true,
    "linkOrdersToInvoices": true
  }
}
