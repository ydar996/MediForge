{
  "version": "1.0",
  "country": "CA",
  "description": "Canadian provincial integration registry. MediForge connects to provincial hubs — not individual labs or pharmacies.",
  "provinces": {
    "ON": {
      "name": "Ontario",
      "enabled": true,
      "healthCardLabel": "OHIP Health Card (PHN)",
      "identifierSystem": "http://ehealthontario.ca/fhir/NamingSystem/id-on-patient-hcn",
      "contacts": {
        "clinicalInterop": "Ontario Health — Digital Services",
        "billing": "Ministry of Health — OHIP/MCEDT",
        "certification": "OntarioMD"
      },
      "hubs": {
        "lab": {
          "name": "OLIS (Ontario Labs Information System)",
          "transport": "hl7",
          "messageTypes": ["ORM^O01", "OML^O21", "ORU^R01"],
          "fhirResources": ["ServiceRequest", "DiagnosticReport", "Observation"],
          "endpointPlaceholder": "https://fhir.example.ehealthontario.ca/r4",
          "mllpPlaceholder": "olis-mllp.example.ehealthontario.ca:2575",
          "onboarding": "OntarioMD EMR certification + OLIS integration agreement"
        },
        "imaging": {
          "name": "Ontario Diagnostic Imaging Repositories (DIR)",
          "transport": "fhir",
          "dicomweb": true,
          "dimseGateway": true,
          "endpointPlaceholder": "https://dir.example.ehealthontario.ca/dicomweb",
          "onboarding": "Hospital/region DIR participation agreement"
        },
        "rx": {
          "name": "Infoway National ePrescribing Service",
          "transport": "fhir",
          "profile": "http://infoway-inforoute.ca/fhir/StructureDefinition/ca-medication-transmission-v2",
          "endpointPlaceholder": "https://rx.example.infoway-inforoute.ca/fhir",
          "onboarding": "Canada Health Infoway partner onboarding + PrescribeIT successor program"
        },
        "billing": {
          "name": "OHIP via MCEDT",
          "transport": "webservice",
          "payerCode": "OHIP",
          "endpointPlaceholder": "https://mcedt.example.health.gov.on.ca",
          "authMethod": "client_certificate",
          "onboarding": "MOH billing number + MCEDT enrollment"
        }
      }
    },
    "BC": {
      "name": "British Columbia",
      "enabled": true,
      "healthCardLabel": "BC Services Card (PHN)",
      "identifierSystem": "http://fhir.bccdc.ca/NamingSystem/bc-phn",
      "contacts": {
        "clinicalInterop": "Provincial Health Services Authority (PHSA)",
        "billing": "Medical Services Plan (MSP)",
        "certification": "PITO / provincial EMR standards"
      },
      "hubs": {
        "lab": {
          "name": "Provincial Lab Information Solution (PLIS)",
          "transport": "hl7",
          "messageTypes": ["ORM^O01", "ORU^R01"],
          "endpointPlaceholder": "https://plis.example.phsa.ca/fhir",
          "onboarding": "PHSA integration agreement"
        },
        "imaging": {
          "name": "BC Provincial Imaging Network",
          "transport": "fhir",
          "dicomweb": true,
          "endpointPlaceholder": "https://pacs.example.phsa.ca/dicomweb",
          "onboarding": "Regional health authority DIR/PACS connection"
        },
        "rx": {
          "name": "Infoway National ePrescribing Service",
          "transport": "fhir",
          "endpointPlaceholder": "https://rx.example.infoway-inforoute.ca/fhir",
          "onboarding": "Infoway partner onboarding"
        },
        "billing": {
          "name": "MSP Teleplan",
          "transport": "webservice",
          "payerCode": "MSP",
          "endpointPlaceholder": "https://teleplan.example.gov.bc.ca",
          "authMethod": "api_key_and_certificate",
          "onboarding": "MSP practitioner enrollment + Teleplan Data Centre Centre ID"
        }
      }
    },
    "AB": {
      "name": "Alberta",
      "enabled": true,
      "healthCardLabel": "Alberta Personal Health Number",
      "identifierSystem": "http://fhir.alberta.ca/NamingSystem/alberta-phn",
      "contacts": {
        "clinicalInterop": "Alberta Health — Connect Care / Netcare",
        "billing": "Alberta Health Care Insurance Plan (AHCIP)",
        "certification": "Alberta Netcare EMR conformance"
      },
      "hubs": {
        "lab": {
          "name": "Alberta Netcare Laboratory",
          "transport": "hl7",
          "messageTypes": ["ORM^O01", "ORU^R01"],
          "endpointPlaceholder": "https://labhub.example.alberta.ca",
          "onboarding": "Alberta Netcare integration agreement"
        },
        "imaging": {
          "name": "Alberta Diagnostic Imaging Repository",
          "transport": "fhir",
          "dicomweb": true,
          "endpointPlaceholder": "https://dir.example.alberta.ca/dicomweb",
          "onboarding": "AHS imaging repository enrollment"
        },
        "rx": {
          "name": "Infoway National ePrescribing Service",
          "transport": "fhir",
          "endpointPlaceholder": "https://rx.example.infoway-inforoute.ca/fhir",
          "onboarding": "Infoway partner onboarding"
        },
        "billing": {
          "name": "AHCIP via HLINK",
          "transport": "webservice",
          "payerCode": "AHCIP",
          "endpointPlaceholder": "https://hlink.example.alberta.ca",
          "authMethod": "client_certificate",
          "onboarding": "AHCIP billing submission ID + HLINK credentials"
        }
      }
    }
  }
}
