{
  "version": "1.0",
  "defaultProvince": "ON",
  "enabled": false,
  "description": "Master integration switch. Set enabled:true after provincial hub onboarding. Province overlays live in config/provinces/.",
  "security": {
    "requireConsent": true,
    "auditAllMessages": true,
    "maxRetries": 3,
    "gatewayApiKeyEnv": "INTEROP_GATEWAY_API_KEY",
    "vpnRequired": true,
    "notes": "Production connections use VPN or mutual TLS certificates issued by the provincial authority."
  },
  "adapters": {
    "lab": "hl7",
    "labMessageType": "ORM^O01",
    "imaging": "fhir",
    "rx": "fhir",
    "claims": "webservice"
  },
  "workflow": {
    "autoTransmitLabOrders": true,
    "autoTransmitImagingOrders": true,
    "autoTransmitSignedPrescriptions": true,
    "autoSubmitClaimsOnInvoice": false,
    "registerPatientIdentifiersOnSave": true
  },
  "billing": {
    "claimPortalUrl": "",
    "remittanceFormat": "json",
    "autoCalculatePatientResponsibility": true
  },
  "documentation": {
    "connectionGuide": "MEDIFORGE-CONNECTION-GUIDE.md",
    "interopDocs": "MEDIFORGE-INTEROPERABILITY-DOCS.md",
    "billingDocs": "MEDIFORGE-BILLING-AND-PAYMENTS-DOCS.md"
  }
}
