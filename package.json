{
  "name": "mediforge",
  "version": "1.0.0",
  "description": "MediForge Multi-tenant Healthcare Platform",
  "scripts": {
    "generate-brochure-pdf": "node scripts/generate-brochure-pdf.js",
    "generate-brochure-pdf-local": "node scripts/generate-brochure-pdf-local.js",
    "manual:screenshots": "node scripts/capture-user-manual-screenshots.cjs",
    "manual:screenshots:connect": "node scripts/capture-user-manual-screenshots.cjs --connect",
    "manual:screenshots:dev": "node scripts/capture-user-manual-screenshots.cjs --seed-auth",
    "manual:screenshots:platform": "node scripts/capture-user-manual-screenshots.cjs --platform",
    "check:icons": "node scripts/check-user-facing-html-icons.mjs",
    "check:patient-identity": "node scripts/check-patient-identity.mjs",
    "check:patient-race": "node scripts/check-patient-race-workflows.mjs",
    "fix:corruption": "node scripts/fix-all-corruption.mjs",
    "scan:corruption": "node scripts/scan-all-corruption.mjs",
    "check:corrupted-text": "node scripts/check-corrupted-text.mjs",
    "check:no-em-dash": "node scripts/check-no-em-dash.mjs",
    "build:icd10ca": "node scripts/build-icd10ca-js.mjs",
    "build:formulary": "node scripts/build-canadian-formulary.mjs",
    "build:nhp-formulary": "node scripts/build-canadian-nhp-formulary.mjs",
    "build:provincial-lab-crosswalks": "node scripts/build-provincial-lab-crosswalks.mjs",
    "check:formulary": "node scripts/check-canadian-formulary.mjs",
    "check:nhp-formulary": "node scripts/check-canadian-nhp-formulary.mjs",
    "check": "npm run check:icons && npm run check:patient-identity && npm run check:patient-race && npm run check:corrupted-text && npm run check:no-em-dash && npm run check:lab-codes && npm run check:formulary",
    "fix:patient-identity-html": "node scripts/ensure-patient-identity-in-html.mjs",
    "db:security-advisors": "node scripts/fetch-security-advisors.mjs",
    "db:security-advisors:rls": "node scripts/fetch-security-advisors.mjs --filter rls_disabled,policy_exists,sensitive",
    "generate:security-redirects": "node scripts/generate-security-redirects.cjs",
    "inject:supabase-env": "node scripts/inject-supabase-env.cjs",
    "sync:vendor": "node scripts/sync-vendor-libs.cjs",
    "test:interop": "node --test tests/interop/*.test.js",
    "test:integrations": "node --test tests/integrations/*.test.js",
    "test:billing": "node --test tests/billing/*.test.js",
    "generate:lab-codes": "node scripts/generate-lab-code-map-canada.mjs",
    "build:diagnostic-catalog": "node scripts/build-diagnostic-catalog.mjs",
    "check:lab-codes": "node scripts/check-lab-code-map-canada.mjs",
    "test:clinical": "node --test tests/interop/*.test.js tests/integrations/*.test.js tests/billing/*.test.js",
    "test:dropdowns": "node scripts/test-address-dropdowns.mjs",
    "test:icd10": "node scripts/test-icd10-pages.mjs",
    "test:icd10:dev": "node scripts/test-icd10-pages.mjs --dev",
    "test:staging-smoke": "node scripts/test-staging-smoke.mjs"
  },
  "devDependencies": {
    "@supabase/supabase-js": "2.106.1",
    "puppeteer": "^25.0.4",
    "supabase": "^2.100.1"
  }
}
